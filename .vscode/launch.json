{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Accounting System",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/accounting/index.js",
      "restart": true,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src/accounting"
    },
    {
      "name": "Debug Accounting System",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/accounting/index.js",
      "restart": true,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src/accounting",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
